{
  "name": "kushcloud",
  "version": "2.0.0",
  "private": false,
  "description": "Flappy bird style stoner game",
  "license": "MIT",
  "author": "Linacre",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit",
    "clean": "rm -rf node_modules dist android/app/build",
    "android": "cap sync android && cap open android",
    "ios": "cap sync ios && cap open ios",
    "cap:build": "npm run build && cap sync"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "clsx": "2.1.1",
    "firebase": "^12.14.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "22.19.17",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^26.0.0",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "7.3.2",
    "vite-plugin-singlefile": "2.3.3",
    "vitest": "^4.1.8"
  }
}
