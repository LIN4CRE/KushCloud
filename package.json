{
  "name": "kushcloud",
  "version": "3.1.0",
  "private": false,
  "description": "Flappy bird style arcade game with canvas physics, real-time Firebase leaderboards, unlockable skins, and daily missions.",
  "license": "MIT",
  "author": "Linacre",
  "type": "module",
  "files": ["dist", "src", "public", "docs", "scripts", "android", "*.md", "LICENSE"],
  "sideEffects": false,
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit",
    "clean": "node -e \"const f=['node_modules','dist','android/app/build'];f.forEach(d=>require('fs').rmSync(d,{recursive:true,force:true}))\"",
    "clean:dist": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "android": "cap sync android && cap open android",
    "ios": "cap sync ios && cap open ios",
    "cap:build": "npm run build && cap sync",
    "release": "echo 'See docs/RELEASE_GUIDE.md for manual release process'"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "clsx": "2.1.1",
    "firebase": "^12.14.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "8.0.16",
    "vite-plugin-singlefile": "2.3.3",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "flappy-bird",
    "game",
    "arcade",
    "react",
    "typescript",
    "capacitor",
    "firebase",
    "canvas",
    "web-audio"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LIN4CRE/KushCloud.git"
  },
  "homepage": "https://lin4cre.github.io/KushCloud/",
  "bugs": {
    "url": "https://github.com/LIN4CRE/KushCloud/issues"
  }
}
